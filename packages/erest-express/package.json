{
  "name": "@erest/express",
  "version": "3.0.0",
  "description": "Express adapter for erest",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "peerDependencies": {
    "erest": "^3.0.0",
    "express": "^4.0.0 || ^5.0.0"
  },
  "devDependencies": {
    "erest": "workspace:*",
    "express": "^4.21.0",
    "@types/express": "^4.17.21",
    "typescript": "^5.8.0"
  }
}
