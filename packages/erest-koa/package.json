{
  "name": "@erest/koa",
  "version": "3.1.0",
  "description": "Koa adapter for erest",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "peerDependencies": {
    "erest": "workspace:^",
    "koa": "^3.0.0",
    "koa-router": "^13.0.0",
    "@koa/router": "^13.0.0"
  },
  "peerDependenciesMeta": {
    "koa-router": { "optional": true },
    "@koa/router": { "optional": true }
  },
  "devDependencies": {
    "erest": "workspace:*",
    "koa": "^3.0.0",
    "koa-router": "^13.1.0",
    "@types/koa": "^2.15.0",
    "@types/koa-router": "^7.4.8",
    "typescript": "^5.8.0"
  }
}
