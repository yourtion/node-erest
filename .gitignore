# 依赖
node_modules/
# npm lock（本工程使用 pnpm，仅保留 pnpm-lock.yaml）
package-lock.json

# 构建产物
dist/
!docs/superpowers
docs/
examples/docs/out/
# 根级 TS 配置的编译产物（vitest.bench.config.ts 等，误 tsc 时会生成同名 .js/.d.ts）
/*.js
/*.d.ts
!vitest.config.ts
# 子包 src 下的散落编译产物（tsc rootDir 未限时会落入 src）
packages/*/src/*.js
packages/*/src/*.d.ts

# 测试覆盖率
coverage/
.nyc_output/

# 日志
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pids/
*.pid
*.pid.lock

# 环境变量
.env

# 包打包产物
*.tgz

# 缓存
.npm/
.eslintcache
.scannerwork

# 编辑器
.idea/
.vscode/
*.swp
.DS_Store
