{
  "name": "erest-example",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "erest 端到端示例：迷你博客业务域，一份 API 定义，三个框架入口。演示 registerTyped/reply、forceGroup、hooks、自定义错误/类型、define/mock、文档生成、测试集成。",
  "scripts": {
    "start:leizmweb": "node src/entries/leizmweb.js",
    "start:express": "node src/entries/express.js",
    "start:koa": "node src/entries/koa.js",
    "dev:leizmweb": "node --watch src/entries/leizmweb.js",
    "dev:express": "node --watch src/entries/express.js",
    "dev:koa": "node --watch src/entries/koa.js",
    "test": "vitest run",
    "docs": "node docs/generate.js"
  },
  "dependencies": {
    "@leizm/web": "^2.7.0",
    "erest": "workspace:*",
    "@erest/express": "workspace:*",
    "@erest/koa": "workspace:*",
    "@erest/leizmweb": "workspace:*",
    "express": "^5.1.0",
    "koa": "^3.0.0",
    "koa-bodyparser": "^4.4.1",
    "koa-router": "^13.1.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "vitest": "^3.0.0"
  }
}
